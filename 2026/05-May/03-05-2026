#include <iostream>
using namespace std;

int main() {
    string str;
    cout << "Enter a string: ";
    cin >> str;

    string rev = "";

    for(int i = str.length() - 1; i >= 0; i--) {
        rev += str[i];
    }

    if(str == rev) {
        cout << "Palindrome" << endl;
    } else {
        cout << "Not Palindrome" << endl;
    }

    return 0;
}
