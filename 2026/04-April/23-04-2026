#include <iostream>
using namespace std;

int main() {
    int n, reversed = 0, remainder;

    cout << "Enter a number: ";
    cin >> n;

    int original = n;

    while(n != 0) {
        remainder = n % 10;
        reversed = reversed * 10 + remainder;
        n /= 10;
    }

    cout << "Reversed number: " << reversed << endl;

    if(original == reversed)
        cout << "It is a palindrome number";
    else
        cout << "It is not a palindrome number";

    return 0;
}
