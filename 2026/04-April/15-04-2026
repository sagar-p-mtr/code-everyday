#include <iostream>
using namespace std;

int main() {
    int n;
    float number, sum = 0;

    cout << "Enter how many numbers you want to add: ";
    cin >> n;

    for(int i = 1; i <= n; i++) {
        cout << "Enter number " << i << ": ";
        cin >> number;
        sum += number;
    }

    cout << "Sum of " << n << " numbers = " << sum;

    return 0;
}
