#include <iostream>
using namespace std;

int main() {
    int a[3][3], temp;

    cout << "Enter 3x3 matrix:\n";

    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            cin >> a[i][j];
        }
    }

    for(int j = 0; j < 3; j++) {
        temp = a[0][j];
        a[0][j] = a[2][j];
        a[2][j] = temp;
    }

    cout << "Matrix after swapping rows:\n";

    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            cout << a[i][j] << " ";
        }
        cout << endl;
    }

    return 0;
}
