#include <iostream>
using namespace std;

int main() {
    int a[3][3], sum = 0;

    cout << "Enter 3x3 matrix:\n";

    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            cin >> a[i][j];
        }
    }

    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            if(i == 0 || i == 2 || j == 0 || j == 2) {
                sum += a[i][j];
            }
        }
    }

    cout << "Sum of boundary elements = " << sum << endl;

    return 0;
}
