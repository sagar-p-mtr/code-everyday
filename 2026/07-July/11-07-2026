#include <iostream>
using namespace std;

int main() {
    int a[3][3];
    int minValue;

    cout << "Enter 3x3 matrix:\n";

    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            cin >> a[i][j];
        }
    }

    minValue = a[0][0];

    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            if(a[i][j] < minValue) {
                minValue = a[i][j];
            }
        }
    }

    cout << "Minimum element = " << minValue << endl;

    return 0;
}
