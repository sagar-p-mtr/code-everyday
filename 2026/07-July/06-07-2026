#include <iostream>
using namespace std;

int main() {
    int matrix[3][3];
    int trace = 0;

    cout << "Enter 3x3 matrix:\n";

    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            cin >> matrix[i][j];
        }
    }

    for(int i = 0; i < 3; i++) {
        trace += matrix[i][i];
    }

    cout << "Trace of the matrix = " << trace << endl;

    return 0;
}
