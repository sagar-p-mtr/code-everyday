#include <iostream>
using namespace std;

int main() {
    int a[3][3];
    bool identity = true;

    cout << "Enter 3x3 matrix:\n";

    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            cin >> a[i][j];
        }
    }

    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            if((i == j && a[i][j] != 1) ||
               (i != j && a[i][j] != 0)) {
                identity = false;
            }
        }
    }

    if(identity)
        cout << "Identity Matrix";
    else
        cout << "Not an Identity Matrix";

    return 0;
}
