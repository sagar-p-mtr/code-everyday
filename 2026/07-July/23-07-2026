#include <iostream>
using namespace std;

int main() {
    int a[3][3];
    long long product = 1;

    cout << "Enter 3x3 matrix:\n";

    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            cin >> a[i][j];
            product *= a[i][j];
        }
    }

    cout << "Product of all elements = " << product << endl;

    return 0;
}
