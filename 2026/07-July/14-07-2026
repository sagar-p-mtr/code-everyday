#include <iostream>
using namespace std;

int main() {
    int a[3][3];
    bool diagonal = true;

    cout << "Enter 3x3 matrix:\n";

    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            cin >> a[i][j];
        }
    }

    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            if(i != j && a[i][j] != 0) {
                diagonal = false;
            }
        }
    }

    if(diagonal)
        cout << "Diagonal Matrix";
    else
        cout << "Not a Diagonal Matrix";

    return 0;
}
