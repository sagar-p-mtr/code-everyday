#include <iostream>
using namespace std;

int main() {
    int a[3][3];
    int maxValue;

    cout << "Enter 3x3 matrix:\n";

    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            cin >> a[i][j];
        }
    }

    maxValue = a[0][0];

    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            if(a[i][j] > maxValue) {
                maxValue = a[i][j];
            }
        }
    }

    cout << "Maximum element = " << maxValue << endl;

    return 0;
}
