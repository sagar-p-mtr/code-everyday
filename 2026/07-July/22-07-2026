#include <iostream>
using namespace std;

int main() {
    int a[3][3];
    int positive = 0, negative = 0, zero = 0;

    cout << "Enter 3x3 matrix:\n";

    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            cin >> a[i][j];

            if(a[i][j] > 0)
                positive++;
            else if(a[i][j] < 0)
                negative++;
            else
                zero++;
        }
    }

    cout << "Positive = " << positive << endl;
    cout << "Negative = " << negative << endl;
    cout << "Zero = " << zero << endl;

    return 0;
}
