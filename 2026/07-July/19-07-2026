#include <iostream>
using namespace std;

int main() {
    int a[3][3];
    int sum = 0;
    float average;

    cout << "Enter 3x3 matrix:\n";

    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            cin >> a[i][j];
            sum += a[i][j];
        }
    }

    average = (float)sum / 9;

    cout << "Sum = " << sum << endl;
    cout << "Average = " << average << endl;

    return 0;
}
