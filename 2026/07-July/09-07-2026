#include <iostream>
using namespace std;

int main() {
    int a[3][3];
    bool upper = true;

    cout << "Enter 3x3 matrix:\n";

    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            cin >> a[i][j];
        }
    }

    for(int i = 1; i < 3; i++) {
        for(int j = 0; j < i; j++) {
            if(a[i][j] != 0) {
                upper = false;
            }
        }
    }

    if(upper)
        cout << "Upper Triangular Matrix";
    else
        cout << "Not an Upper Triangular Matrix";

    return 0;
}
