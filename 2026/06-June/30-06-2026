#include <iostream>
using namespace std;

int main() {
    int arr[100], n, visited[100] = {0};

    cout << "Enter number of elements: ";
    cin >> n;

    cout << "Enter elements:\n";
    for(int i = 0; i < n; i++)
        cin >> arr[i];

    cout << "Element\tFrequency\n";

    for(int i = 0; i < n; i++) {
        if(visited[i] == 1)
            continue;

        int count = 1;

        for(int j = i + 1; j < n; j++) {
            if(arr[i] == arr[j]) {
                count++;
                visited[j] = 1;
            }
        }

        cout << arr[i] << "\t" << count << endl;
    }

    return 0;
}
