#include <iostream>
using namespace std;

int main() {
    int n, arr[100], sum = 0;

    cout << "Enter value of n: ";
    cin >> n;

    cout << "Enter " << n - 1 << " numbers:\n";
    for(int i = 0; i < n - 1; i++) {
        cin >> arr[i];
        sum += arr[i];
    }

    int total = n * (n + 1) / 2;
    int missing = total - sum;

    cout << "Missing number = " << missing << endl;

    return 0;
}
