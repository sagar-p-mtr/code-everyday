#include <iostream>
#include <cmath>
using namespace std;

int main() {
    int num;

    cout << "Enter a number: ";
    cin >> num;

    int root = sqrt(num);

    if(root * root == num)
        cout << num << " is a Perfect Square";
    else
        cout << num << " is Not a Perfect Square";

    return 0;
}
