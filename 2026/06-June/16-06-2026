#include <iostream>
using namespace std;

int main() {
    int n;
    long long factorial = 1;

    cout << "Enter a number: ";
    cin >> n;

    if(n < 0) {
        cout << "Factorial does not exist";
    }
    else {
        for(int i = 1; i <= n; i++) {
            factorial *= i;
        }

        cout << "Factorial = " << factorial << endl;
    }

    return 0;
}
